# ===========================================
# OENOCLASS - Variables d'environnement
# ===========================================
# Copiez ce fichier vers .env et remplissez les valeurs

# Base de donnees PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/oenoclass?schema=public"

# Better Auth
BETTER_AUTH_SECRET="votre-secret-de-32-caracteres-minimum"
BETTER_AUTH_URL="http://localhost:3000"

# GAR SAML (Production)
GAR_SAML_ENTRY_POINT="https://idp-auth.gar.education.fr/domaineGar/Shibboleth.sso/SAML2/POST"
GAR_SAML_ISSUER="votre-entity-id-gar"
GAR_SAML_CERT="chemin/vers/certificat-gar.pem"
GAR_SAML_PRIVATE_KEY="chemin/vers/cle-privee.pem"

# OpenAI (pour le sommelier IA)
OPENAI_API_KEY="sk-..."

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
